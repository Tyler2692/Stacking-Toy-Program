Red = "\033[91m"
Orange = "\033[38;2;255;165;0m"
Yellow = "\033[93m"
Green = "\033[92m"
Blue = "\033[94m"


def fillstack(stack):


    stack.append(Red + "Red")
    stack.append(Orange + "Orange")
    stack.append(Yellow + "Yellow")
    stack.append(Green + "Green")
    stack.append(Blue + "Blue")


def printstack(stack):
   
    for i in range(len(stack)-1, -1, -1):
        print(stack[i])
       
stack = []


fillstack(stack)
printstack(stack)
